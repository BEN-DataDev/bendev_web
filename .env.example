PUBLIC_SUPABASE_URL=<your_supabase_project_url>
PUBLIC_SUPABASE_ANON_KEY=<your_supabase_anon_key>

# Supabase MCP (hosted) + CLI convenience (DO NOT COMMIT REAL VALUES)
# - SUPABASE_PROJECT_REF is the ref in your Supabase dashboard URL
# - SUPABASE_ACCESS_TOKEN is a Supabase Personal Access Token (PAT)
SUPABASE_PROJECT_REF=<your_supabase_project_ref>
SUPABASE_ACCESS_TOKEN=<your_supabase_personal_access_token>