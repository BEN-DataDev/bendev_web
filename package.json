{
	"name": "bendev-web",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"update-db-types": "npx supabase gen types typescript --project-id \"$SUPABASE_PROJECT_REF\" > src/lib/db.types.ts",
		"update-db-types-local": "npx supabase gen types --local --lang=typescript --schema public > src/lib/db.types.ts"
	},
	"devDependencies": {
		"@geoman-io/leaflet-geoman-free": "^2.17.0",
		"@skeletonlabs/skeleton": "^4.12.0",
		"@skeletonlabs/skeleton-svelte": "^4.12.0",
		"@supabase/ssr": "^0.5.1",
		"@supabase/supabase-js": "^2.45.6",
		"@sveltejs/adapter-vercel": "^5.4.7",
		"@sveltejs/kit": "^2.7.2",
		"@sveltejs/vite-plugin-svelte": "^4.0.0",
		"@tailwindcss/vite": "^4.1.18",
		"@types/eslint": "^9.6.1",
		"@types/leaflet": "^1.9.14",
		"@types/shpjs": "^3.4.7",
		"@zxcvbn-ts/core": "^3.0.4",
		"@zxcvbn-ts/language-common": "^3.0.4",
		"@zxcvbn-ts/language-en": "^3.0.2",
		"eslint": "^9.13.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.46.0",
		"globals": "^15.11.0",
		"html2canvas": "^1.4.1",
		"leaflet": "^1.9.4",
		"lucide-svelte": "^0.564.0",
		"maplibre-gl": "^4.7.1",
		"prettier": "^3.3.3",
		"prettier-plugin-svelte": "^3.2.7",
		"prettier-plugin-tailwindcss": "^0.6.8",
		"supabase": "^2.76.8",
		"svelte": "^5.1.0",
		"svelte-check": "^4.0.5",
		"tailwind-merge": "^3.4.1",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.6.3",
		"typescript-eslint": "^8.11.0",
		"vite": "^5.4.10"
	},
	"type": "module",
	"dependencies": {
		"@tmcw/togeojson": "^7.1.2",
		"mapbox-gl-esri-sources": "^0.0.7",
		"shpjs": "^6.2.0"
	}
}
